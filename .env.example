# .env
# ----
# Local development environment variables.
# Copy this file to .env and fill in real values.
# NEVER commit a .env with real secrets to git.

# API authentication key (clients must send this in the X-API-Key header)
API_KEY=dev-secret-key

# OpenAI integration (optional) — leave empty to use the rule-based mock
OPENAI_API_KEY=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to true only for local debugging
DEBUG=false
